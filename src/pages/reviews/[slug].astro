---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await render(review);

// Calculate reading time
const wordCount = (review.body || '').split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 200));
const readingTime = `${readMinutes} min read`;

// Build Product JSON-LD with aggregateRating
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: review.data.product,
  description: review.data.description,
  image: review.data.image,
  ...(review.data.affiliate_link ? { url: review.data.affiliate_link } : {}),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: review.data.rating,
    bestRating: 5,
    worstRating: 1,
    reviewCount: 1,
  },
  review: {
    '@type': 'Review',
    author: {
      '@type': 'Person',
      name: review.data.author || 'AI Tools Team',
    },
    datePublished: review.data.date.toISOString().split('T')[0],
    reviewRating: {
      '@type': 'Rating',
      ratingValue: review.data.rating,
      bestRating: 5,
      worstRating: 1,
    },
  },
};
---

<ArticleLayout
  title={review.data.title}
  description={review.data.description}
  date={review.data.date}
  author={review.data.author}
  image={review.data.image}
  tags={review.data.tags}
  category="review"
  breadcrumb={[{ label: 'Reviews', href: '/reviews' }]}
  jsonLd={jsonLd}
  readingTime={readingTime}
>
  <!-- Rating Box -->
  <div class="bg-[#fafafa] rounded-2xl p-6 sm:p-8 mb-8" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 mb-6">
      <h2 class="text-xl font-semibold text-[#171717]" style="letter-spacing: -0.96px;">{review.data.product}</h2>
      <div class="flex items-center gap-2">
        <div class="flex gap-0.5">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg class={`w-5 h-5 ${i < review.data.rating ? 'text-[#171717]' : 'text-[#bbb]'}`} fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <span class="text-[#171717] font-semibold text-lg">{review.data.rating}</span>
        <span class="text-[#666] text-sm">/5</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {review.data.pros.length > 0 && (
        <div class="p-4 bg-white rounded-xl" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
          <h3 class="text-sm font-semibold text-[#171717] mb-3 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
            Pros
          </h3>
          <ul class="space-y-2">
            {review.data.pros.map((pro) => (
              <li class="text-sm text-[#4d4d4d] flex items-start gap-2">
                <span class="text-[#171717] mt-0.5 flex-shrink-0">+</span>
                {pro}
              </li>
            ))}
          </ul>
        </div>
      )}
      {review.data.cons.length > 0 && (
        <div class="p-4 bg-white rounded-xl" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
          <h3 class="text-sm font-semibold text-[#171717] mb-3 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" /></svg>
            Cons
          </h3>
          <ul class="space-y-2">
            {review.data.cons.map((con) => (
              <li class="text-sm text-[#4d4d4d] flex items-start gap-2">
                <span class="text-[#171717] mt-0.5 flex-shrink-0">−</span>
                {con}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    {review.data.pricing && (
      <div class="mt-4 pt-4 flex items-center gap-2" style="box-shadow: inset 0px 1px 0px 0px rgba(0,0,0,0.08);">
        <svg class="w-4 h-4 text-[#666]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="text-sm text-[#4d4d4d]">Pricing: </span>
        <span class="text-sm text-[#171717] font-medium">{review.data.pricing}</span>
      </div>
    )}

    {review.data.affiliate_link && (
      <div class="mt-6">
        <a
          href={review.data.affiliate_link}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="inline-flex items-center gap-2 px-6 py-3 bg-[#171717] hover:bg-[#333] text-white font-medium rounded-lg transition-colors text-sm"
        >
          Try {review.data.product}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
        <p class="text-xs text-[#666] mt-2">Affiliate link · See our <a href="/affiliate-disclosure" class="text-[#0072f5] hover:underline">disclosure</a></p>
      </div>
    )}
  </div>

  <Content />
</ArticleLayout>
