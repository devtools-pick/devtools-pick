---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await render(review);
---

<ArticleLayout
  title={review.data.title}
  description={review.data.description}
  date={review.data.date}
  author={review.data.author}
  image={review.data.image}
  tags={review.data.tags}
  category="review"
  breadcrumb={[{ label: 'Reviews', href: '/reviews' }]}
>
  <!-- Rating Box -->
  <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 mb-8">
    <div class="flex items-center gap-3 mb-4">
      <h2 class="text-xl font-bold text-white">{review.data.product}</h2>
      <div class="flex gap-1">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class={`w-5 h-5 ${i < review.data.rating ? 'text-amber-400' : 'text-slate-600'}`} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {review.data.pros.length > 0 && (
        <div>
          <h3 class="text-sm font-semibold text-emerald-400 mb-2">✓ Pros</h3>
          <ul class="space-y-1">
            {review.data.pros.map((pro) => (
              <li class="text-sm text-slate-300">{pro}</li>
            ))}
          </ul>
        </div>
      )}
      {review.data.cons.length > 0 && (
        <div>
          <h3 class="text-sm font-semibold text-red-400 mb-2">✗ Cons</h3>
          <ul class="space-y-1">
            {review.data.cons.map((con) => (
              <li class="text-sm text-slate-300">{con}</li>
            ))}
          </ul>
        </div>
      )}
    </div>

    {review.data.pricing && (
      <div class="mt-4 pt-4 border-t border-slate-700">
        <span class="text-sm text-slate-400">Pricing: </span>
        <span class="text-sm text-white font-medium">{review.data.pricing}</span>
      </div>
    )}

    {review.data.affiliate_link && (
      <a
        href={review.data.affiliate_link}
        target="_blank"
        rel="noopener noreferrer nofollow"
        class="mt-4 inline-block px-6 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors"
      >
        Try {review.data.product} →
      </a>
    )}
  </div>

  <Content />
</ArticleLayout>
