---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reviews = (await getCollection('reviews'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="AI Tool Reviews" description="In-depth reviews of the latest AI tools. Expert analysis, pricing, pros and cons.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-[#171717] mb-4">AI Tool Reviews</h1>
    <p class="text-[#666] mb-8 max-w-2xl">Honest, in-depth reviews of AI tools to help you make informed decisions.</p>

    {reviews.length === 0 ? (
      <p class="text-[#999] text-center py-12">No reviews yet. Check back soon!</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviews.map((review) => (
          <a href={`/reviews/${review.id}`} class="block p-6 rounded-xl bg-white transition-all group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08)">
            <div class="flex items-center gap-2 mb-3">
              <span class="px-2 py-1 bg-[#ebf5ff] text-[#0068d6] rounded text-xs font-medium">Review</span>
              <div class="flex gap-0.5">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-3 h-3 ${i < review.data.rating ? 'text-amber-400' : 'text-[#ddd]'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <h3 class="text-lg font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors">{review.data.title}</h3>
            <p class="text-[#666] text-sm mb-3 line-clamp-2">{review.data.description}</p>
            <div class="text-[#999] text-xs">
              <span>{review.data.product}</span>
              {review.data.pricing && <span> · {review.data.pricing}</span>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
