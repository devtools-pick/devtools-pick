---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const allComparisons = await getCollection('comparisons');
const allAlternatives = await getCollection('alternatives');
const allBestof = await getCollection('bestof');

const recentReviews = allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentComparisons = allComparisons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentAlternatives = allAlternatives.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentBestof = allBestof.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const categoryStyles: Record<string, { gradient: string; border: string; badge: string; label: string }> = {
  reviews: {
    gradient: 'from-indigo-500/10 to-transparent',
    border: 'border-indigo-500/20',
    badge: 'bg-indigo-500/20 text-indigo-300',
    label: 'Reviews',
  },
  comparisons: {
    gradient: 'from-cyan-500/10 to-transparent',
    border: 'border-cyan-500/20',
    badge: 'bg-cyan-500/20 text-cyan-300',
    label: 'Comparisons',
  },
  alternatives: {
    gradient: 'from-violet-500/10 to-transparent',
    border: 'border-violet-500/20',
    badge: 'bg-violet-500/20 text-violet-300',
    label: 'Alternatives',
  },
  bestof: {
    gradient: 'from-amber-500/10 to-transparent',
    border: 'border-amber-500/20',
    badge: 'bg-amber-500/20 text-amber-300',
    label: 'Best Of',
  },
};

function getSlug(collection: string, entry: any): string {
  return `/${collection}/${entry.id}`;
}
---

<BaseLayout title="AI Tools Hub" description="Your trusted source for AI tool reviews, comparisons, alternatives, and best-of lists. Find the perfect AI tools for your workflow.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/5 via-transparent to-transparent"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        Find the Best <span class="bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">AI Tools</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-8">
        Expert reviews, comparisons, and recommendations to help you choose the right AI tools for your workflow.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/reviews" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors">
          Browse Reviews
        </a>
        <a href="/best-of" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-lg border border-slate-700 transition-colors">
          Best Of Lists
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  {recentReviews.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Latest Reviews</h2>
        <a href="/reviews" class="text-indigo-400 hover:text-indigo-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentReviews.map((review) => (
          <a href={getSlug('reviews', review)} class={`block p-6 rounded-xl border ${categoryStyles.reviews.border} bg-gradient-to-br ${categoryStyles.reviews.gradient} hover:border-indigo-500/40 transition-all group`}>
            <span class={`inline-block px-2 py-1 rounded text-xs font-medium mb-3 ${categoryStyles.reviews.badge}`}>Review</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-indigo-300 transition-colors">{review.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{review.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{review.data.product}</span>
              <span>·</span>
              <span>{review.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Comparisons Section -->
  {recentComparisons.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Latest Comparisons</h2>
        <a href="/comparisons" class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentComparisons.map((comp) => (
          <a href={getSlug('comparisons', comp)} class={`block p-6 rounded-xl border ${categoryStyles.comparisons.border} bg-gradient-to-br ${categoryStyles.comparisons.gradient} hover:border-cyan-500/40 transition-all group`}>
            <span class={`inline-block px-2 py-1 rounded text-xs font-medium mb-3 ${categoryStyles.comparisons.badge}`}>Comparison</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-cyan-300 transition-colors">{comp.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{comp.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{comp.data.products.join(' vs ')}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Alternatives Section -->
  {recentAlternatives.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Latest Alternatives</h2>
        <a href="/alternatives" class="text-violet-400 hover:text-violet-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentAlternatives.map((alt) => (
          <a href={getSlug('alternatives', alt)} class={`block p-6 rounded-xl border ${categoryStyles.alternatives.border} bg-gradient-to-br ${categoryStyles.alternatives.gradient} hover:border-violet-500/40 transition-all group`}>
            <span class={`inline-block px-2 py-1 rounded text-xs font-medium mb-3 ${categoryStyles.alternatives.badge}`}>Alternatives</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-violet-300 transition-colors">{alt.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{alt.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{alt.data.alternatives_list.length} alternatives</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Best Of Section -->
  {recentBestof.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-white">Best Of Lists</h2>
        <a href="/best-of" class="text-amber-400 hover:text-amber-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentBestof.map((best) => (
          <a href={getSlug('bestof', best)} class={`block p-6 rounded-xl border ${categoryStyles.bestof.border} bg-gradient-to-br ${categoryStyles.bestof.gradient} hover:border-amber-500/40 transition-all group`}>
            <span class={`inline-block px-2 py-1 rounded text-xs font-medium mb-3 ${categoryStyles.bestof.badge}`}>Best Of</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-amber-300 transition-colors">{best.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{best.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{best.data.tools.length} tools listed</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Empty State -->
  {recentReviews.length === 0 && recentComparisons.length === 0 && recentAlternatives.length === 0 && recentBestof.length === 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="max-w-lg mx-auto">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3">Content Coming Soon</h2>
        <p class="text-slate-400">We're working on the best AI tool reviews, comparisons, and recommendations. Check back soon!</p>
      </div>
    </section>
  )}
</BaseLayout>
