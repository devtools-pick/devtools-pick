---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const allComparisons = await getCollection('comparisons');
const allAlternatives = await getCollection('alternatives');
const allBestof = await getCollection('bestof');

const recentReviews = allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentComparisons = allComparisons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentAlternatives = allAlternatives.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentBestof = allBestof.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const totalArticles = allReviews.length + allComparisons.length + allAlternatives.length + allBestof.length;

const categoryMeta: Record<string, { label: string; count: number; href: string; accent: string }> = {
  reviews: { label: 'Reviews', count: allReviews.length, href: '/reviews', accent: '#0072f5' },
  comparisons: { label: 'Comparisons', count: allComparisons.length, href: '/comparisons', accent: '#0072f5' },
  alternatives: { label: 'Alternatives', count: allAlternatives.length, href: '/alternatives', accent: '#0072f5' },
  bestof: { label: 'Best Of', count: allBestof.length, href: '/best-of', accent: '#0072f5' },
};

function getSlug(collection: string, entry: any): string {
  return `/${collection}/${entry.id}`;
}
---

<BaseLayout title="AI Tools Hub" description="Your trusted source for AI tool reviews, comparisons, alternatives, and best-of lists. Find the perfect AI tools for your workflow.">
  <!-- Hero Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-[#171717] mb-6 leading-[1.05]" style="letter-spacing: -2.4px;">
      Find the best AI tools<br class="hidden sm:block" /> for your workflow
    </h1>
    <p class="text-lg text-[#4d4d4d] max-w-2xl mx-auto mb-4 leading-relaxed">
      Honest, in-depth reviews and comparisons to help developers choose the right AI tools — no hype, no fluff, just real experience.
    </p>
    <p class="text-sm text-[#999] mb-10">
      {totalArticles} articles · Updated weekly · By developers, for developers
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/reviews" class="w-full sm:w-auto px-6 py-3 bg-[#171717] hover:bg-[#333] text-white font-medium rounded-lg transition-colors text-sm">
        Browse Reviews
      </a>
      <a href="/best-of" class="w-full sm:w-auto px-6 py-3 bg-white text-[#171717] font-medium rounded-lg transition-colors text-sm" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
        Best Of Lists
      </a>
    </div>
  </section>

  <!-- Category Quick Links -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {Object.entries(categoryMeta).map(([key, meta]) => (
        <a href={meta.href} class="flex items-center gap-3 p-4 rounded-xl bg-white transition-all hover:shadow-md group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
          <div class="p-2 rounded-lg bg-[#f5f5f5]">
            <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <span class="text-[#171717] text-sm font-medium">{meta.label}</span>
            <p class="text-[#999] text-xs">{meta.count} articles</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Reviews Section -->
  {recentReviews.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-[#171717]" style="letter-spacing: -0.96px;">Latest Reviews</h2>
        <a href="/reviews" class="text-[#0072f5] hover:underline text-sm font-medium">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {recentReviews.map((review) => (
          <a href={getSlug('reviews', review)} class="block p-5 rounded-xl bg-white transition-all hover:shadow-md group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium mb-3 bg-[#f5f5f5] text-[#4d4d4d]">Review</span>
            <h3 class="text-base font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors leading-snug" style="letter-spacing: -0.48px;">{review.data.title}</h3>
            <p class="text-[#4d4d4d] text-sm mb-4 line-clamp-2">{review.data.description}</p>
            <div class="flex items-center justify-between text-xs">
              <span class="font-medium text-[#4d4d4d]">{review.data.product}</span>
              <span class="text-[#999]">{review.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Comparisons Section -->
  {recentComparisons.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-[#171717]" style="letter-spacing: -0.96px;">Latest Comparisons</h2>
        <a href="/comparisons" class="text-[#0072f5] hover:underline text-sm font-medium">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {recentComparisons.map((comp) => (
          <a href={getSlug('comparisons', comp)} class="block p-5 rounded-xl bg-white transition-all hover:shadow-md group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium mb-3 bg-[#f5f5f5] text-[#4d4d4d]">Comparison</span>
            <h3 class="text-base font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors leading-snug" style="letter-spacing: -0.48px;">{comp.data.title}</h3>
            <p class="text-[#4d4d4d] text-sm mb-4 line-clamp-2">{comp.data.description}</p>
            <div class="flex items-center gap-2 text-xs text-[#999]">
              <span>{comp.data.products.join(' vs ')}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Alternatives Section -->
  {recentAlternatives.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-[#171717]" style="letter-spacing: -0.96px;">Latest Alternatives</h2>
        <a href="/alternatives" class="text-[#0072f5] hover:underline text-sm font-medium">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {recentAlternatives.map((alt) => (
          <a href={getSlug('alternatives', alt)} class="block p-5 rounded-xl bg-white transition-all hover:shadow-md group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium mb-3 bg-[#f5f5f5] text-[#4d4d4d]">Alternatives</span>
            <h3 class="text-base font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors leading-snug" style="letter-spacing: -0.48px;">{alt.data.title}</h3>
            <p class="text-[#4d4d4d] text-sm mb-4 line-clamp-2">{alt.data.description}</p>
            <div class="flex items-center gap-2 text-xs text-[#999]">
              <span>{alt.data.alternatives_list.length} alternatives</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Best Of Section -->
  {recentBestof.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-[#171717]" style="letter-spacing: -0.96px;">Best Of Lists</h2>
        <a href="/best-of" class="text-[#0072f5] hover:underline text-sm font-medium">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {recentBestof.map((best) => (
          <a href={getSlug('bestof', best)} class="block p-5 rounded-xl bg-white transition-all hover:shadow-md group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08), 0px 2px 4px rgba(0,0,0,0.04);">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium mb-3 bg-[#f5f5f5] text-[#4d4d4d]">Best Of</span>
            <h3 class="text-base font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors leading-snug" style="letter-spacing: -0.48px;">{best.data.title}</h3>
            <p class="text-[#4d4d4d] text-sm mb-4 line-clamp-2">{best.data.description}</p>
            <div class="flex items-center gap-2 text-xs text-[#999]">
              <span>{best.data.tools.length} tools listed</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Why Trust Us Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-semibold text-[#171717] text-center mb-10" style="letter-spacing: -1.2px;">Why Trust Our Reviews?</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="w-12 h-12 bg-[#f5f5f5] rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        </div>
        <h3 class="text-[#171717] font-semibold mb-2 text-sm">Hands-On Testing</h3>
        <p class="text-[#4d4d4d] text-sm leading-relaxed">Every tool is tested by real developers in real projects. No sponsored fluff or copy-paste reviews.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-12 h-12 bg-[#f5f5f5] rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
        </div>
        <h3 class="text-[#171717] font-semibold mb-2 text-sm">Transparent Disclosure</h3>
        <p class="text-[#4d4d4d] text-sm leading-relaxed">We clearly mark affiliate links. Our editorial opinions are never influenced by partnerships.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-12 h-12 bg-[#f5f5f5] rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
        </div>
        <h3 class="text-[#171717] font-semibold mb-2 text-sm">Always Up to Date</h3>
        <p class="text-[#4d4d4d] text-sm leading-relaxed">AI tools evolve fast. We revisit and update our reviews regularly to keep pace with changes.</p>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="rounded-2xl p-8 sm:p-10 bg-[#fafafa]" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
      <h2 class="text-xl font-semibold text-[#171717] mb-2" style="letter-spacing: -0.96px;">Stay in the Loop</h2>
      <p class="text-[#4d4d4d] text-sm mb-6">Get the latest AI tool reviews and comparisons delivered to your inbox. No spam, unsubscribe anytime.</p>
      <form class="flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); alert('Thanks for subscribing! (Demo)')">
        <input
          type="email"
          placeholder="you@example.com"
          class="flex-1 px-4 py-3 bg-white rounded-lg text-[#171717] placeholder-[#999] focus:outline-none focus:ring-2 focus:ring-[#0072f5] text-sm"
          style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-[#171717] hover:bg-[#333] text-white font-medium rounded-lg transition-colors text-sm whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p class="text-[#999] text-xs mt-3">Join 2,000+ developers. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- Empty State -->
  {recentReviews.length === 0 && recentComparisons.length === 0 && recentAlternatives.length === 0 && recentBestof.length === 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="max-w-lg mx-auto">
        <div class="w-14 h-14 bg-[#f5f5f5] rounded-xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h2 class="text-xl font-semibold text-[#171717] mb-3" style="letter-spacing: -0.96px;">Content Coming Soon</h2>
        <p class="text-[#4d4d4d]">We're working on the best AI tool reviews, comparisons, and recommendations. Check back soon!</p>
      </div>
    </section>
  )}
</BaseLayout>
