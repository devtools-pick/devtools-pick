---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const allComparisons = await getCollection('comparisons');
const allAlternatives = await getCollection('alternatives');
const allBestof = await getCollection('bestof');

const recentReviews = allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentComparisons = allComparisons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentAlternatives = allAlternatives.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
const recentBestof = allBestof.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);

const totalArticles = allReviews.length + allComparisons.length + allAlternatives.length + allBestof.length;

const categoryStyles: Record<string, { gradient: string; border: string; badge: string; label: string; icon: string }> = {
  reviews: {
    gradient: 'from-indigo-500/10 to-transparent',
    border: 'border-indigo-500/20',
    badge: 'bg-indigo-500/20 text-indigo-300',
    label: 'Reviews',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
  },
  comparisons: {
    gradient: 'from-cyan-500/10 to-transparent',
    border: 'border-cyan-500/20',
    badge: 'bg-cyan-500/20 text-cyan-300',
    label: 'Comparisons',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>`,
  },
  alternatives: {
    gradient: 'from-violet-500/10 to-transparent',
    border: 'border-violet-500/20',
    badge: 'bg-violet-500/20 text-violet-300',
    label: 'Alternatives',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
  },
  bestof: {
    gradient: 'from-amber-500/10 to-transparent',
    border: 'border-amber-500/20',
    badge: 'bg-amber-500/20 text-amber-300',
    label: 'Best Of',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
  },
};

function getSlug(collection: string, entry: any): string {
  return `/${collection}/${entry.id}`;
}
---

<BaseLayout title="AI Tools Hub" description="Your trusted source for AI tool reviews, comparisons, alternatives, and best-of lists. Find the perfect AI tools for your workflow.">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-indigo-500/8 via-transparent to-transparent"></div>
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-cyan-500/10 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-sm font-medium mb-8">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        Updated for 2026
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 tracking-tight leading-tight">
        Find the <span class="hero-gradient bg-clip-text text-transparent">Best AI Tools</span> for Your Workflow
      </h1>
      <p class="text-lg sm:text-xl text-slate-400 max-w-2xl mx-auto mb-4 leading-relaxed">
        Honest, in-depth reviews and comparisons to help developers choose the right AI tools — no hype, no fluff, just real experience.
      </p>
      <p class="text-sm text-slate-500 mb-10">
        {totalArticles} articles · Updated weekly · By developers, for developers
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/reviews" class="w-full sm:w-auto px-8 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-indigo-500/25 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Browse Reviews
        </a>
        <a href="/best-of" class="w-full sm:w-auto px-8 py-3.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-xl border border-slate-700 transition-all hover:border-slate-600 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          Best Of Lists
        </a>
      </div>
    </div>
  </section>

  <!-- Category Quick Links -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-2 mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {Object.entries(categoryStyles).map(([key, style]) => (
        <a href={`/${key === 'bestof' ? 'best-of' : key}`} class={`flex items-center gap-3 p-4 rounded-xl border ${style.border} bg-gradient-to-br ${style.gradient} hover:scale-105 transition-all group`}>
          <div class={`p-2 rounded-lg ${style.badge}`} set:html={style.icon} />
          <div>
            <span class="text-white text-sm font-semibold group-hover:text-opacity-80">{style.label}</span>
            <p class="text-slate-500 text-xs">
              {key === 'reviews' ? allReviews.length : key === 'comparisons' ? allComparisons.length : key === 'alternatives' ? allAlternatives.length : allBestof.length} articles
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Reviews Section -->
  {recentReviews.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="p-2 rounded-lg bg-indigo-500/20">
            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h2 class="text-2xl font-bold text-white">Latest Reviews</h2>
        </div>
        <a href="/reviews" class="text-indigo-400 hover:text-indigo-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentReviews.map((review) => (
          <a href={getSlug('reviews', review)} class={`block p-6 rounded-xl border ${categoryStyles.reviews.border} bg-gradient-to-br ${categoryStyles.reviews.gradient} hover:border-indigo-500/40 hover:shadow-lg hover:shadow-indigo-500/5 transition-all group`}>
            <span class={`inline-block px-2.5 py-1 rounded-lg text-xs font-medium mb-3 ${categoryStyles.reviews.badge}`}>Review</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-indigo-300 transition-colors leading-snug">{review.data.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-2">{review.data.description}</p>
            <div class="flex items-center justify-between text-slate-500 text-xs">
              <span class="font-medium text-slate-400">{review.data.product}</span>
              <span>{review.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Comparisons Section -->
  {recentComparisons.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="p-2 rounded-lg bg-cyan-500/20">
            <svg class="w-5 h-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
          </div>
          <h2 class="text-2xl font-bold text-white">Latest Comparisons</h2>
        </div>
        <a href="/comparisons" class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentComparisons.map((comp) => (
          <a href={getSlug('comparisons', comp)} class={`block p-6 rounded-xl border ${categoryStyles.comparisons.border} bg-gradient-to-br ${categoryStyles.comparisons.gradient} hover:border-cyan-500/40 hover:shadow-lg hover:shadow-cyan-500/5 transition-all group`}>
            <span class={`inline-block px-2.5 py-1 rounded-lg text-xs font-medium mb-3 ${categoryStyles.comparisons.badge}`}>Comparison</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-cyan-300 transition-colors leading-snug">{comp.data.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-2">{comp.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{comp.data.products.join(' vs ')}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Alternatives Section -->
  {recentAlternatives.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="p-2 rounded-lg bg-violet-500/20">
            <svg class="w-5 h-5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </div>
          <h2 class="text-2xl font-bold text-white">Latest Alternatives</h2>
        </div>
        <a href="/alternatives" class="text-violet-400 hover:text-violet-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentAlternatives.map((alt) => (
          <a href={getSlug('alternatives', alt)} class={`block p-6 rounded-xl border ${categoryStyles.alternatives.border} bg-gradient-to-br ${categoryStyles.alternatives.gradient} hover:border-violet-500/40 hover:shadow-lg hover:shadow-violet-500/5 transition-all group`}>
            <span class={`inline-block px-2.5 py-1 rounded-lg text-xs font-medium mb-3 ${categoryStyles.alternatives.badge}`}>Alternatives</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-violet-300 transition-colors leading-snug">{alt.data.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-2">{alt.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{alt.data.alternatives_list.length} alternatives</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Best Of Section -->
  {recentBestof.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="p-2 rounded-lg bg-amber-500/20">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <h2 class="text-2xl font-bold text-white">Best Of Lists</h2>
        </div>
        <a href="/best-of" class="text-amber-400 hover:text-amber-300 text-sm font-medium transition-colors">View all →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {recentBestof.map((best) => (
          <a href={getSlug('bestof', best)} class={`block p-6 rounded-xl border ${categoryStyles.bestof.border} bg-gradient-to-br ${categoryStyles.bestof.gradient} hover:border-amber-500/40 hover:shadow-lg hover:shadow-amber-500/5 transition-all group`}>
            <span class={`inline-block px-2.5 py-1 rounded-lg text-xs font-medium mb-3 ${categoryStyles.bestof.badge}`}>Best Of</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-amber-300 transition-colors leading-snug">{best.data.title}</h3>
            <p class="text-slate-400 text-sm mb-4 line-clamp-2">{best.data.description}</p>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <span>{best.data.tools.length} tools listed</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Why Trust Us Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-white text-center mb-10">Why Trust Our Reviews?</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center p-6">
        <div class="w-14 h-14 bg-gradient-to-br from-indigo-500/20 to-cyan-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-indigo-500/20">
          <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Hands-On Testing</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Every tool is tested by real developers in real projects. No sponsored fluff or copy-paste reviews.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 bg-gradient-to-br from-emerald-500/20 to-teal-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-emerald-500/20">
          <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Transparent Disclosure</h3>
        <p class="text-slate-400 text-sm leading-relaxed">We clearly mark affiliate links. Our editorial opinions are never influenced by partnerships.</p>
      </div>
      <div class="text-center p-6">
        <div class="w-14 h-14 bg-gradient-to-br from-amber-500/20 to-orange-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-amber-500/20">
          <svg class="w-7 h-7 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
        </div>
        <h3 class="text-white font-semibold mb-2">Always Up to Date</h3>
        <p class="text-slate-400 text-sm leading-relaxed">AI tools evolve fast. We revisit and update our reviews regularly to keep pace with changes.</p>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="relative overflow-hidden rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-800 p-8 sm:p-10">
      <div class="absolute top-0 right-0 w-40 h-40 bg-indigo-500/10 rounded-full blur-3xl"></div>
      <div class="relative">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Stay in the Loop</h2>
        <p class="text-slate-400 text-sm mb-6">Get the latest AI tool reviews and comparisons delivered to your inbox. No spam, unsubscribe anytime.</p>
        <form class="flex flex-col sm:flex-row gap-3" onsubmit="event.preventDefault(); alert('Thanks for subscribing! (Demo)')">
          <input
            type="email"
            placeholder="you@example.com"
            class="flex-1 px-4 py-3 bg-slate-800 border border-slate-700 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all text-sm"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-indigo-500/25 text-sm whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p class="text-slate-600 text-xs mt-3">Join 2,000+ developers. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <!-- Empty State -->
  {recentReviews.length === 0 && recentComparisons.length === 0 && recentAlternatives.length === 0 && recentBestof.length === 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="max-w-lg mx-auto">
        <div class="w-16 h-16 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-2xl flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-3">Content Coming Soon</h2>
        <p class="text-slate-400">We're working on the best AI tool reviews, comparisons, and recommendations. Check back soon!</p>
      </div>
    </section>
  )}
</BaseLayout>
