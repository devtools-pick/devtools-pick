---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service" description="Terms and conditions for using the AI Tools Hub website.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-[#171717] mb-6">Terms of Service</h1>

    <div class="prose prose-lg max-w-none">
      <p class="text-[#666] leading-relaxed">
        <strong class="text-[#171717]">Last updated:</strong> {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>

      <div class="p-5 rounded-xl border border-[#e5e7eb] bg-[#f8f9fa] my-8">
        <p class="text-[#555] text-sm leading-relaxed">
          <strong class="text-[#171717]">Disclaimer:</strong> These terms are a template for informational purposes and do not constitute legal advice. Please consult a qualified attorney to ensure compliance with applicable laws.
        </p>
      </div>

      <h2 class="text-[#171717] text-xl font-bold mt-8 mb-4">1. Acceptance of Terms</h2>
