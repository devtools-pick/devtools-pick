---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const alternatives = (await getCollection('alternatives'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="AI Tool Alternatives" description="Discover the best alternatives to popular AI tools. Find similar tools that might better suit your needs.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">AI Tool Alternatives</h1>
    <p class="text-slate-400 mb-8 max-w-2xl">Looking for alternatives? We've got you covered with detailed comparisons.</p>

    {alternatives.length === 0 ? (
      <p class="text-slate-500 text-center py-12">No alternatives listed yet. Check back soon!</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {alternatives.map((alt) => (
          <a href={`/alternatives/${alt.id}`} class="block p-6 rounded-xl border border-violet-500/20 bg-gradient-to-br from-violet-500/10 to-transparent hover:border-violet-500/40 transition-all group">
            <span class="inline-block px-2 py-1 bg-violet-500/20 text-violet-300 rounded text-xs font-medium mb-3">Alternatives</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-violet-300 transition-colors">{alt.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{alt.data.description}</p>
            <div class="text-slate-500 text-xs">
              {alt.data.alternatives_list.length} alternatives to {alt.data.original_product}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
