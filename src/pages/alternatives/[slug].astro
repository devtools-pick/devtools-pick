---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const alternatives = await getCollection('alternatives');
  return alternatives.map((alt) => ({
    params: { slug: alt.id },
    props: { alt },
  }));
}

const { alt } = Astro.props;
const { Content } = await render(alt);

// Calculate reading time
const wordCount = (alt.body || '').split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 200));
const readingTime = `${readMinutes} min read`;

// Build ItemList JSON-LD for alternatives
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: alt.data.title,
  description: alt.data.description,
  itemListElement: alt.data.alternatives_list.map((item: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: item.name,
      description: item.description,
      aggregateRating: item.rating ? {
        '@type': 'AggregateRating',
        ratingValue: item.rating,
        bestRating: 5,
        worstRating: 1,
      } : undefined,
    },
  })),
  numberOfItems: alt.data.alternatives_list.length,
};
---

<ArticleLayout
  title={alt.data.title}
  description={alt.data.description}
  date={alt.data.date}
  author={alt.data.author}
  image={alt.data.image}
  tags={alt.data.tags}
  category="alternatives"
  breadcrumb={[{ label: 'Alternatives', href: '/alternatives' }]}
  jsonLd={jsonLd}
  readingTime={readingTime}
>
  <!-- Alternatives Summary -->
  <div class="bg-[#f8f9fa] border border-[#e5e7eb] rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold text-[#171717] mb-2">Alternatives to {alt.data.original_product}</h2>
    <p class="text-[#666] text-sm mb-4">Here are {alt.data.alternatives_list.length} great alternatives you should consider.</p>
    <div class="space-y-3">
      {alt.data.alternatives_list.map((item: any, i: number) => (
        <div class="flex items-start gap-3 p-3 bg-white rounded-lg">
          <span class="flex-shrink-0 w-6 h-6 bg-violet-500/20 text-violet-300 rounded-full flex items-center justify-center text-xs font-bold">
            {i + 1}
          </span>
          <div>
            <h3 class="text-[#171717] font-medium text-sm">{item.name}</h3>
            <p class="text-[#666] text-xs">{item.description}</p>
            {item.rating && (
              <div class="flex gap-0.5 mt-1">
                {Array.from({ length: 5 }).map((_: any, j: number) => (
                  <svg class={`w-3 h-3 ${j < item.rating! ? 'text-[#d97706]' : 'text-[#ddd]'}`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <Content />
</ArticleLayout>
