---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionBox from '../../components/DecisionBox.astro';

export async function getStaticPaths() {
  const bestof = await getCollection('bestof');
  return bestof.map((best) => ({
    params: { slug: best.id },
    props: { best },
  }));
}

const { best } = Astro.props;
const { Content } = await render(best);

// Calculate reading time
const wordCount = (best.body || '').split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.ceil(wordCount / 200));
const readingTime = `${readMinutes} min read`;

// Build ItemList JSON-LD for best-of
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: best.data.title,
  description: best.data.description,
  itemListElement: best.data.tools.map((tool: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: tool.name,
      description: tool.description,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: tool.rating,
        bestRating: 5,
        worstRating: 1,
      },
    },
  })),
  numberOfItems: best.data.tools.length,
};
---

<ArticleLayout
  title={best.data.title}
  description={best.data.description}
  date={best.data.date}
  author={best.data.author}
  image={best.data.image}
  tags={best.data.tags}
  category="bestof"
  breadcrumb={[{ label: 'Best Of', href: '/best-of' }]}
  jsonLd={jsonLd}
  readingTime={readingTime}
>
  <!-- Decision Box (money page component — above the fold) -->
  {best.data.decisionBox && (
    <DecisionBox
      bestFor={best.data.decisionBox.bestFor}
      skipIf={best.data.decisionBox.skipIf}
      cheapestPlan={best.data.decisionBox.cheapestPlan}
      teamPick={best.data.decisionBox.teamPick}
    />
  )}

  <!-- Tools Overview -->
  <div class="bg-[#f8f9fa] rounded-xl p-6 mb-8" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
    <h2 class="text-lg font-bold text-[#171717] mb-4">Featured Tools ({best.data.tools.length})</h2>
    <div class="space-y-3">
      {best.data.tools.map((tool: any, i: number) => (
        <div class="flex items-start gap-3 p-3 bg-white rounded-lg" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
          <span class={`flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${
            i === 0 ? 'bg-[#fef3c7] text-[#d97706]' : 'bg-[#f1f5f9] text-[#64748b]'
          }`}>
            #{i + 1}
          </span>
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <h3 class="text-[#171717] font-medium">{tool.name}</h3>
              {tool.highlight && (
                <span class="px-2 py-0.5 bg-[#fef3c7] text-[#d97706] rounded text-xs">{tool.highlight}</span>
              )}
            </div>
            <p class="text-[#666] text-sm mt-1">{tool.description}</p>
            <div class="flex gap-0.5 mt-2">
              {Array.from({ length: 5 }).map((_: any, j: number) => (
                <svg class={`w-4 h-4 ${j < tool.rating ? 'text-[#d97706]' : 'text-[#ddd]'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Content />
</ArticleLayout>
