---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const bestof = await getCollection('bestof');
  return bestof.map((best) => ({
    params: { slug: best.id },
    props: { best },
  }));
}

const { best } = Astro.props;
const { Content } = await render(best);
---

<ArticleLayout
  title={best.data.title}
  description={best.data.description}
  date={best.data.date}
  author={best.data.author}
  image={best.data.image}
  tags={best.data.tags}
  category="bestof"
  breadcrumb={[{ label: 'Best Of', href: '/best-of' }]}
>
  <!-- Tools Overview -->
  <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold text-white mb-4">Featured Tools ({best.data.tools.length})</h2>
    <div class="space-y-3">
      {best.data.tools.map((tool, i) => (
        <div class="flex items-start gap-3 p-3 bg-slate-900/50 rounded-lg">
          <span class={`flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold ${
            i === 0 ? 'bg-amber-500/20 text-amber-300' : 'bg-slate-700/50 text-slate-400'
          }`}>
            #{i + 1}
          </span>
          <div class="flex-1">
            <div class="flex items-center gap-2">
              <h3 class="text-white font-medium">{tool.name}</h3>
              {tool.highlight && (
                <span class="px-2 py-0.5 bg-amber-500/20 text-amber-300 rounded text-xs">{tool.highlight}</span>
              )}
            </div>
            <p class="text-slate-400 text-sm mt-1">{tool.description}</p>
            <div class="flex gap-0.5 mt-2">
              {Array.from({ length: 5 }).map((_, j) => (
                <svg class={`w-4 h-4 ${j < tool.rating ? 'text-amber-400' : 'text-slate-600'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <Content />
</ArticleLayout>
