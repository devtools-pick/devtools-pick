---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const bestof = (await getCollection('bestof'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Best AI Tools" description="Our curated lists of the best AI tools for various use cases. Expert picks and recommendations.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-[#171717] mb-4">Best AI Tools</h1>
    <p class="text-[#666] mb-8 max-w-2xl">Curated lists of the best AI tools, handpicked by our experts.</p>

    {bestof.length === 0 ? (
      <p class="text-[#999] text-center py-12">No lists yet. Check back soon!</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {bestof.map((best) => (
          <a href={`/best-of/${best.id}`} class="block p-6 rounded-xl bg-white transition-all group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08)">
            <span class="inline-block px-2 py-1 bg-[#ebf5ff] text-[#0068d6] rounded text-xs font-medium mb-3">Best Of</span>
            <h3 class="text-lg font-semibold text-[#171717] mb-2 group-hover:text-[#0072f5] transition-colors">{best.data.title}</h3>
            <p class="text-[#666] text-sm mb-3 line-clamp-2">{best.data.description}</p>
            <div class="text-[#999] text-xs">
              {best.data.tools.length} tools listed
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
