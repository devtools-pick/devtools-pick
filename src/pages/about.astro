---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about AI Tools Hub — our mission, how we test AI tools, and why developers trust our reviews.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <!-- Header -->
    <header class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">About AI Tools Hub</h1>
      <p class="text-lg text-slate-400 leading-relaxed">
        We're a team of developers and AI enthusiasts on a mission to cut through the noise and help you find the right AI tools for your workflow.
      </p>
    </header>

    <!-- Mission -->
    <section class="mb-12">
      <div class="p-6 sm:p-8 rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-800/50">
        <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
          <span class="p-2 bg-indigo-500/10 rounded-lg border border-indigo-500/20">
            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </span>
          Our Mission
        </h2>
        <p class="text-slate-300 leading-relaxed mb-4">
          The AI tools landscape is overwhelming. New products launch every week, each claiming to be revolutionary. Developers need a reliable, no-nonsense resource to figure out what actually works.
        </p>
        <p class="text-slate-300 leading-relaxed">
          That's why we built AI Tools Hub. Every review is based on hands-on testing in real projects. We don't accept payment for positive reviews, and we clearly disclose every affiliate relationship.
        </p>
      </div>
    </section>

    <!-- How We Test -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-6">How We Test</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔬</span>
            <h3 class="text-white font-semibold">Hands-On Testing</h3>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">We use every tool in real development workflows for at least two weeks before writing a review. No reading marketing pages — we actually build things.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">📊</span>
            <h3 class="text-white font-semibold">Structured Evaluation</h3>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">Each tool is scored on features, pricing, ease of use, performance, and support. We use the same criteria across all reviews for fair comparisons.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔄</span>
            <h3 class="text-white font-semibold">Regular Updates</h3>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">AI tools change fast. We revisit our reviews every 3 months and update them when products release major features, change pricing, or significantly improve.</p>
        </div>
        <div class="p-5 rounded-xl border border-slate-800 bg-slate-900/50">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🎯</span>
            <h3 class="text-white font-semibold">Developer Perspective</h3>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">We write for developers, by developers. No marketing fluff, no buzzword salad. Just practical insights about what works and what doesn't.</p>
        </div>
      </div>
    </section>

    <!-- Editorial Policy -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-white mb-6">Editorial Policy</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-3 p-4 rounded-xl border border-emerald-500/10 bg-emerald-500/5">
          <svg class="w-5 h-5 text-emerald-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <p class="text-slate-300 text-sm leading-relaxed"><strong class="text-white">No paid positive reviews.</strong> Our opinions are our own. Affiliate relationships never influence our ratings or recommendations.</p>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl border border-emerald-500/10 bg-emerald-500/5">
          <svg class="w-5 h-5 text-emerald-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <p class="text-slate-300 text-sm leading-relaxed"><strong class="text-white">Transparent disclosures.</strong> Every affiliate link is clearly marked. We earn a commission only when you purchase through our links — at no extra cost to you.</p>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl border border-emerald-500/10 bg-emerald-500/5">
          <svg class="w-5 h-5 text-emerald-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          <p class="text-slate-300 text-sm leading-relaxed"><strong class="text-white">Honest pros and cons.</strong> Every tool has strengths and weaknesses. We don't sugarcoat bad experiences or downplay genuine advantages.</p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="p-6 sm:p-8 rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-800/50 text-center">
      <h2 class="text-xl font-bold text-white mb-2">Get in Touch</h2>
      <p class="text-slate-400 text-sm mb-4">Have a question, suggestion, or want to report an error? We'd love to hear from you.</p>
      <a href="mailto:hello@aitools.dev" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-xl transition-all">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        hello@aitools.dev
      </a>
    </section>
  </div>
</BaseLayout>
