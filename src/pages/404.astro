---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="mb-8">
      <span class="text-8xl font-semibold text-[#e5e5e5]" style="letter-spacing: -4px;">404</span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-semibold text-[#171717] mb-4" style="letter-spacing: -1.2px;">
      Page not found
    </h1>
    <p class="text-[#4d4d4d] text-lg mb-10 max-w-md mx-auto leading-relaxed">
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-16">
      <a href="/" class="w-full sm:w-auto px-6 py-3 bg-[#171717] hover:bg-[#333] text-white font-medium rounded-lg transition-colors text-sm">
        ← Back to Home
      </a>
      <a href="/reviews" class="w-full sm:w-auto px-6 py-3 bg-white text-[#171717] font-medium rounded-lg transition-colors text-sm" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.08);">
        Browse Reviews
      </a>
    </div>

    <div class="text-left max-w-lg mx-auto">
      <h2 class="text-sm font-semibold text-[#4d4d4d] uppercase tracking-wider mb-4">Popular Pages</h2>
      <ul class="space-y-3">
        <li>
          <a href="/reviews" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#fafafa] transition-colors group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
            <span class="w-8 h-8 bg-[#f5f5f5] rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </span>
            <div>
              <span class="text-sm font-medium text-[#171717] group-hover:text-[#0072f5] transition-colors">AI Tool Reviews</span>
              <p class="text-xs text-[#666]">In-depth hands-on reviews of popular AI tools</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/comparisons" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#fafafa] transition-colors group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
            <span class="w-8 h-8 bg-[#f5f5f5] rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
            </span>
            <div>
              <span class="text-sm font-medium text-[#171717] group-hover:text-[#0072f5] transition-colors">Comparisons</span>
              <p class="text-xs text-[#666]">Side-by-side feature and pricing comparisons</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/best-of" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#fafafa] transition-colors group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
            <span class="w-8 h-8 bg-[#f5f5f5] rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
            </span>
            <div>
              <span class="text-sm font-medium text-[#171717] group-hover:text-[#0072f5] transition-colors">Best Of Lists</span>
              <p class="text-xs text-[#666]">Curated lists of the best AI tools by category</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/alternatives" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#fafafa] transition-colors group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
            <span class="w-8 h-8 bg-[#f5f5f5] rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            </span>
            <div>
              <span class="text-sm font-medium text-[#171717] group-hover:text-[#0072f5] transition-colors">Alternatives</span>
              <p class="text-xs text-[#666]">Find alternatives to popular AI tools</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/resources" class="flex items-center gap-3 p-3 rounded-lg hover:bg-[#fafafa] transition-colors group" style="box-shadow: 0px 0px 0px 1px rgba(0,0,0,0.06);">
            <span class="w-8 h-8 bg-[#f5f5f5] rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            </span>
            <div>
              <span class="text-sm font-medium text-[#171717] group-hover:text-[#0072f5] transition-colors">Free Resources</span>
              <p class="text-xs text-[#666]">Free AI tools, courses, and guides for developers</p>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
