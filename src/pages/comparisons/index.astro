---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = (await getCollection('comparisons'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="AI Tool Comparisons" description="Side-by-side comparisons of leading AI tools. Find out which tool is right for your needs.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">AI Tool Comparisons</h1>
    <p class="text-slate-400 mb-8 max-w-2xl">Side-by-side comparisons to help you choose the right AI tool.</p>

    {comparisons.length === 0 ? (
      <p class="text-slate-500 text-center py-12">No comparisons yet. Check back soon!</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {comparisons.map((comp) => (
          <a href={`/comparisons/${comp.id}`} class="block p-6 rounded-xl border border-cyan-500/20 bg-gradient-to-br from-cyan-500/10 to-transparent hover:border-cyan-500/40 transition-all group">
            <span class="inline-block px-2 py-1 bg-cyan-500/20 text-cyan-300 rounded text-xs font-medium mb-3">Comparison</span>
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-cyan-300 transition-colors">{comp.data.title}</h3>
            <p class="text-slate-400 text-sm mb-3 line-clamp-2">{comp.data.description}</p>
            <div class="text-slate-500 text-xs">
              {comp.data.products.join(' vs ')}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
