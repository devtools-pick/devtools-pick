---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
  category: string;
  breadcrumb?: { label: string; href: string }[];
}

const {
  title, description, date, author = 'AI Tools Team', image, tags = [], category, breadcrumb = []
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryColors: Record<string, string> = {
  review: 'bg-indigo-500/20 text-indigo-300 border-indigo-500/30',
  comparison: 'bg-cyan-500/20 text-cyan-300 border-cyan-500/30',
  alternatives: 'bg-violet-500/20 text-violet-300 border-violet-500/30',
  bestof: 'bg-amber-500/20 text-amber-300 border-amber-500/30',
};
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        {breadcrumb.map((crumb) => (
          <>
            <span>/</span>
            <a href={crumb.href} class="hover:text-white transition-colors">{crumb.label}</a>
          </>
        ))}
      </nav>
    )}

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class={`px-3 py-1 rounded-full text-xs font-medium border ${categoryColors[category] || 'bg-slate-500/20 text-slate-300 border-slate-500/30'}`}>
          {category.charAt(0).toUpperCase() + category.slice(1)}
        </span>
        <time class="text-slate-500 text-sm">{formattedDate}</time>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{title}</h1>
      <p class="text-lg text-slate-400">{description}</p>
      <div class="flex items-center gap-3 mt-4">
        <div class="w-8 h-8 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-full flex items-center justify-center">
          <span class="text-white text-xs font-bold">{author.charAt(0)}</span>
        </div>
        <div>
          <p class="text-white text-sm font-medium">{author}</p>
          <p class="text-slate-500 text-xs">Published {formattedDate}</p>
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    {image && (
      <div class="mb-8 rounded-xl overflow-hidden border border-slate-800">
        <img src={image} alt={title} class="w-full h-auto object-cover" loading="lazy" />
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-12 pt-8 border-t border-slate-800">
        <h3 class="text-sm font-semibold text-slate-400 mb-3">Tags</h3>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm hover:bg-slate-700 transition-colors cursor-pointer">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
