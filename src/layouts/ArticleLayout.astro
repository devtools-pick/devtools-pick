---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  tags?: string[];
  category: string;
  breadcrumb?: { label: string; href: string }[];
}

const {
  title, description, date, author = 'AI Tools Team', image, tags = [], category, breadcrumb = []
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryColors: Record<string, string> = {
  review: 'bg-indigo-500/20 text-indigo-300 border-indigo-500/30',
  comparison: 'bg-cyan-500/20 text-cyan-300 border-cyan-500/30',
  alternatives: 'bg-violet-500/20 text-violet-300 border-violet-500/30',
  bestof: 'bg-amber-500/20 text-amber-300 border-amber-500/30',
};

const categoryAccent: Record<string, string> = {
  review: 'indigo',
  comparison: 'cyan',
  alternatives: 'violet',
  bestof: 'amber',
};

const accent = categoryAccent[category] || 'indigo';

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
---

<BaseLayout title={title} description={description} image={image} type="article">
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-12">
      <!-- Main Content Column -->
      <div>
        <!-- Breadcrumb -->
        {breadcrumb.length > 0 && (
          <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
            <a href="/" class="hover:text-white transition-colors">Home</a>
            {breadcrumb.map((crumb) => (
              <>
                <span>/</span>
                <a href={crumb.href} class="hover:text-white transition-colors">{crumb.label}</a>
              </>
            ))}
          </nav>
        )}

        <!-- Header -->
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class={`px-3 py-1 rounded-full text-xs font-medium border ${categoryColors[category] || 'bg-slate-500/20 text-slate-300 border-slate-500/30'}`}>
              {category.charAt(0).toUpperCase() + category.slice(1)}
            </span>
            <time class="text-slate-500 text-sm">{formattedDate}</time>
            <span class="text-slate-600">·</span>
            <span class="text-slate-500 text-sm">5 min read</span>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">{title}</h1>
          <p class="text-lg text-slate-400 leading-relaxed">{description}</p>
          <div class="flex items-center gap-3 mt-4">
            <div class="w-9 h-9 bg-gradient-to-br from-indigo-500 to-cyan-500 rounded-full flex items-center justify-center">
              <span class="text-white text-xs font-bold">{author.charAt(0)}</span>
            </div>
            <div>
              <p class="text-white text-sm font-medium">{author}</p>
              <p class="text-slate-500 text-xs">Published {formattedDate}</p>
            </div>
          </div>
        </header>

        <!-- Featured Image -->
        {image && (
          <div class="mb-8 rounded-xl overflow-hidden border border-slate-800">
            <img src={image} alt={title} class="w-full h-auto object-cover" loading="lazy" />
          </div>
        )}

        <!-- Content -->
        <div class="prose prose-lg max-w-none">
          <slot />
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-slate-800">
            <h3 class="text-sm font-semibold text-slate-400 mb-3">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="px-3 py-1 bg-slate-800 text-slate-300 rounded-full text-sm hover:bg-slate-700 transition-colors cursor-pointer">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Share Buttons -->
        <div class="mt-10 pt-8 border-t border-slate-800">
          <h3 class="text-sm font-semibold text-slate-400 mb-4">Share this article</h3>
          <div class="flex flex-wrap gap-3">
            <a
              href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn inline-flex items-center gap-2 px-4 py-2.5 bg-[#1a1a2e] hover:bg-[#16213e] border border-slate-700 hover:border-slate-600 rounded-xl text-slate-300 hover:text-white text-sm font-medium transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Twitter
            </a>
            <a
              href={`https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn inline-flex items-center gap-2 px-4 py-2.5 bg-[#1a1a2e] hover:bg-[#16213e] border border-slate-700 hover:border-slate-600 rounded-xl text-slate-300 hover:text-white text-sm font-medium transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
              Reddit
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn inline-flex items-center gap-2 px-4 py-2.5 bg-[#1a1a2e] hover:bg-[#16213e] border border-slate-700 hover:border-slate-600 rounded-xl text-slate-300 hover:text-white text-sm font-medium transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
            <button
              onclick="navigator.clipboard.writeText(window.location.href).then(() => { this.textContent = '✓ Copied!'; setTimeout(() => { this.textContent = 'Copy Link'; }, 2000) })"
              class="share-btn inline-flex items-center gap-2 px-4 py-2.5 bg-[#1a1a2e] hover:bg-[#16213e] border border-slate-700 hover:border-slate-600 rounded-xl text-slate-300 hover:text-white text-sm font-medium transition-all"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" /></svg>
              Copy Link
            </button>
          </div>
        </div>

        <!-- Was This Helpful? -->
        <div class="mt-10 p-6 bg-slate-800/50 border border-slate-700 rounded-xl text-center">
          <h3 class="text-white font-semibold mb-2">Was this article helpful?</h3>
          <p class="text-slate-400 text-sm mb-4">Let us know so we can improve our content.</p>
          <div class="flex items-center justify-center gap-3">
            <button
              onclick="this.textContent = '✓ Thanks!'; this.disabled = true; document.querySelector('#feedback-no').disabled = true;"
              class="feedback-btn px-5 py-2.5 bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/30 text-emerald-400 rounded-xl text-sm font-medium transition-all"
            >
              👍 Yes, helpful
            </button>
            <button
              id="feedback-no"
              onclick="this.textContent = '✓ Thanks for feedback!'; this.disabled = true; document.querySelector('.feedback-btn').disabled = true;"
              class="feedback-btn px-5 py-2.5 bg-slate-700/50 hover:bg-slate-700 border border-slate-600 text-slate-300 rounded-xl text-sm font-medium transition-all"
            >
              👎 Not really
            </button>
          </div>
        </div>

        <!-- Affiliate Disclosure Banner (in-article) -->
        <div class="mt-8 p-4 bg-amber-500/5 border border-amber-500/20 rounded-xl">
          <p class="text-xs text-amber-200/70 leading-relaxed">
            <strong class="text-amber-300">Affiliate Disclosure:</strong> Some links on this page are affiliate links. We may earn a commission if you make a purchase through these links, at no additional cost to you. This helps support our independent reviews. <a href="/affiliate-disclosure" class="underline hover:text-amber-300">Learn more</a>.
          </p>
        </div>
      </div>

      <!-- Floating Table of Contents Sidebar (desktop only) -->
      <aside class="hidden lg:block">
        <nav class="toc-sidebar" id="toc-sidebar">
          <div class="p-4 bg-slate-800/30 border border-slate-800 rounded-xl">
            <h4 class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Table of Contents</h4>
            <ul id="toc-list" class="space-y-1.5 text-sm">
              <!-- Populated by JS -->
            </ul>
          </div>
        </nav>
      </aside>
    </div>
  </article>

  <!-- Back to Top Button -->
  <button
    id="back-to-top"
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    class="fixed bottom-6 right-6 z-50 p-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full shadow-lg shadow-indigo-500/25 transition-all hover:scale-110"
    aria-label="Back to top"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
  </button>

  <script>
    // Back to top visibility
    const backToTop = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        backToTop?.classList.add('visible');
      } else {
        backToTop?.classList.remove('visible');
      }
    });

    // Table of Contents generation
    function buildTOC() {
      const content = document.querySelector('.prose');
      const tocList = document.getElementById('toc-list');
      if (!content || !tocList) return;

      const headings = content.querySelectorAll('h2, h3');
      if (headings.length === 0) return;

      headings.forEach((heading, i) => {
        // Ensure each heading has an id
        if (!heading.id) {
          heading.id = heading.textContent?.trim()
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/(^-|-$)/g, '') || `heading-${i}`;
        }

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${heading.id}`;
        a.textContent = heading.textContent?.trim() || '';
        a.className = `block py-1 text-slate-400 hover:text-white transition-colors border-l-2 border-transparent hover:border-indigo-500 pl-3 ${
          heading.tagName === 'H3' ? 'ml-3 text-xs' : 'text-sm'
        }`;
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Highlight active heading on scroll
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              tocList.querySelectorAll('a').forEach((link) => {
                link.classList.remove('!text-white', '!border-indigo-500');
                link.classList.add('text-slate-400');
                if (link.getAttribute('href') === `#${id}`) {
                  link.classList.add('!text-white', '!border-indigo-500');
                  link.classList.remove('text-slate-400');
                }
              });
            }
          });
        },
        { rootMargin: '-80px 0px -80% 0px' }
      );

      headings.forEach((h) => observer.observe(h));
    }

    buildTOC();
  </script>
</BaseLayout>
