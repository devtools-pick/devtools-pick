---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalURL = Astro.url.href,
  image = '/og-default.png',
  type = 'website',
} = Astro.props;

const siteName = 'AI Tools Hub';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="en" class="bg-white text-[#171717]">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="AI Tools Hub" />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={image} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Geist Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&display=swap" rel="stylesheet" />

  <title>{fullTitle}</title>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": type === 'article' ? 'Article' : 'WebSite',
    "name": fullTitle,
    "description": description,
    "url": canonicalURL,
    ...(type === 'article' ? {} : { "publisher": { "@type": "Organization", "name": siteName } })
  })} />
</head>
<body class="min-h-screen flex flex-col bg-white text-[#171717]">
  <!-- Navigation -->
  <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md" style="box-shadow: 0px 1px 0px 0px rgba(0,0,0,0.08);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 bg-[#171717] rounded-lg flex items-center justify-center group-hover:opacity-80 transition-opacity">
            <span class="text-white font-semibold text-xs tracking-tight">AI</span>
          </div>
          <span class="text-[#171717] font-semibold text-base hidden sm:block tracking-tight">AI Tools Hub</span>
        </a>
        <div class="hidden md:flex items-center gap-1">
          <a href="/reviews" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">Reviews</a>
          <a href="/comparisons" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">Comparisons</a>
          <a href="/alternatives" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">Alternatives</a>
          <a href="/best-of" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">Best Of</a>
          <a href="/resources" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">Resources</a>
          <a href="/about" class="px-3 py-2 text-[#4d4d4d] hover:text-[#171717] rounded-lg transition-colors text-sm font-medium">About</a>
        </div>
        <div class="md:hidden">
          <button id="mobile-menu-btn" class="text-[#4d4d4d] hover:text-[#171717] p-2 rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden pb-4 mt-1 pt-3" style="box-shadow: 0px 1px 0px 0px rgba(0,0,0,0.08);">
        <div class="flex flex-col gap-1">
          <a href="/reviews" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">Reviews</a>
          <a href="/comparisons" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">Comparisons</a>
          <a href="/alternatives" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">Alternatives</a>
          <a href="/best-of" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">Best Of</a>
          <a href="/resources" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">Resources</a>
          <a href="/about" class="text-[#4d4d4d] hover:text-[#171717] px-3 py-2.5 rounded-lg transition-colors text-sm font-medium">About</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Global Affiliate Disclosure Banner -->
  <div class="bg-[#fafafa]" style="box-shadow: inset 0px 1px 0px 0px rgba(0,0,0,0.08), inset 0px -1px 0px 0px rgba(0,0,0,0.08);">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-shrink-0 p-2 bg-[#f5f5f5] rounded-lg">
          <svg class="w-5 h-5 text-[#4d4d4d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div>
          <p class="text-sm text-[#4d4d4d] leading-relaxed">
            <strong class="text-[#171717]">Affiliate Disclosure:</strong> AI Tools Hub is supported by our readers. Some links on this site are affiliate links, meaning we may earn a commission if you make a purchase through them — at no extra cost to you.
          </p>
          <a href="/affiliate-disclosure" class="text-xs text-[#0072f5] hover:underline mt-1 inline-block">Read our full affiliate disclosure →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-white" style="box-shadow: inset 0px 1px 0px 0px rgba(0,0,0,0.08);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <div class="w-7 h-7 bg-[#171717] rounded-md flex items-center justify-center">
              <span class="text-white font-semibold text-[10px]">AI</span>
            </div>
            <span class="text-[#171717] font-semibold text-sm tracking-tight">AI Tools Hub</span>
          </div>
          <p class="text-[#4d4d4d] text-sm leading-relaxed">Your trusted source for AI tool reviews, comparisons, and recommendations.</p>
        </div>
        <div>
          <h3 class="text-[#171717] font-semibold text-sm mb-4">Content</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/reviews" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Reviews</a></li>
            <li><a href="/comparisons" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Comparisons</a></li>
            <li><a href="/alternatives" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Alternatives</a></li>
            <li><a href="/best-of" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Best Of</a></li>
            <li><a href="/resources" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Free Resources</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-[#171717] font-semibold text-sm mb-4">Company</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/about" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">About Us</a></li>
            <li><a href="/affiliate-disclosure" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Affiliate Disclosure</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-[#171717] font-semibold text-sm mb-4">Legal</h3>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/privacy" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Privacy Policy</a></li>
            <li><a href="/terms" class="text-[#4d4d4d] hover:text-[#171717] transition-colors">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-8 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-[#4d4d4d] text-sm" style="box-shadow: inset 0px 1px 0px 0px rgba(0,0,0,0.08);">
        <p>&copy; {new Date().getFullYear()} AI Tools Hub. All rights reserved.</p>
        <p class="text-xs text-[#666]">Made with ❤️ for the developer community</p>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
  </script>
</body>
</html>
