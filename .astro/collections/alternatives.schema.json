{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "AI Tools Team",
      "type": "string"
    },
    "category": {
      "default": "alternatives",
      "type": "string"
    },
    "original_product": {
      "type": "string"
    },
    "alternatives_list": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "rating": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "name",
          "description"
        ]
      }
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "original_product",
    "alternatives_list"
  ]
}