{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "AI Tools Team",
      "type": "string"
    },
    "category": {
      "default": "review",
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "product": {
      "type": "string"
    },
    "pricing": {
      "type": "string"
    },
    "pros": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cons": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affiliate_link": {
      "type": "string",
      "format": "uri"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "rating",
    "product"
  ]
}