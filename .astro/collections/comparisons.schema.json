{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "author": {
      "default": "AI Tools Team",
      "type": "string"
    },
    "category": {
      "default": "comparison",
      "type": "string"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "winner": {
      "type": "string"
    },
    "image": {
      "type": "string"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affiliate_links": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "products"
  ]
}